{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Bash(cargo check:*)",
      "Bash(cargo insta:*)",
      "Bash(cargo tree:*)",
      "Bash(cat:*)",
