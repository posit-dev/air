'language-server:Start a language server' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'air help commands' commands "$@"
}
(( $+functions[_air__help__completion_commands] )) ||
_air__help__completion_commands() {
    local commands; commands=()
    _describe -t commands 'air help completion commands' commands "$@"
}
