complete -c air -n "__fish_air_using_subcommand completion" -s h -l help -d 'Print help'
complete -c air -n "__fish_air_using_subcommand format" -l log-level -d 'The log level. One of: `error`, `warn`, `info`, `debug`, or `trace`. Defaults to `warn`' -r
